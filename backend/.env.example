# Copy to .env and adjust values. Never commit real secrets.

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_this_to_a_random_string

# Public URL of the API (used in verification emails)
APP_URL=http://localhost:8080
# Next.js origin (CORS + links)
APP_FRONTEND_URL=http://localhost:3000

# PostgreSQL (Docker or local). PHPUnit forces sqlite in tests/bootstrap.php.
DATABASE_URL="postgresql://orkestria:orkestria@127.0.0.1:5432/orkestria?serverVersion=16&charset=utf8"

MAILER_DSN=null://null
MAILER_FROM="Orkestria <noreply@example.com>"

# Regex allowed by nelmio_cors (example: localhost dev)
CORS_ALLOW_ORIGIN='^https?://localhost(:[0-9]+)?$'

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Lexik JWT — generate keys: php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_jwt_passphrase

VAR_DUMPER_SERVER=127.0.0.1:9912

# Fichiers uploadés (voir parameter app.uploads_dir → var/uploads par défaut)
