<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Rapport projet — {{ project.title }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; color: #1e293b; font-size: 14px; padding: 40px; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
    .logo { font-size: 22px; font-weight: 700; color: #5b21b6; letter-spacing: -0.5px; }
    .generated { font-size: 12px; color: #94a3b8; }
    .title-block { margin-bottom: 32px; padding-bottom: 20px; border-bottom: 2px solid #e2e8f0; }
    .title-block h1 { font-size: 26px; font-weight: 700; color: #1e293b; }
    .title-block .client-name { color: #5b21b6; font-size: 14px; font-weight: 600; margin-top: 4px; }
    .title-block .dates { color: #64748b; font-size: 12px; margin-top: 4px; }
    .meta-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 32px; }
    .meta-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px; }
    .meta-card .label { font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .meta-card .value { font-size: 15px; font-weight: 600; color: #1e293b; }
    .meta-card .value.purple { color: #5b21b6; }
    .stage-badge { display: inline-block; padding: 3px 10px; border-radius: 9999px; background: #ede9fe; color: #5b21b6; font-size: 11px; font-weight: 600; }
    .section-title { font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .section-title::before { content: ''; display: block; width: 4px; height: 18px; background: #5b21b6; border-radius: 2px; }

    /* Progress bar */
    .progress-section { margin-bottom: 32px; }
    .progress-bar-wrap { height: 10px; background: #e2e8f0; border-radius: 9999px; overflow: hidden; margin-bottom: 8px; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #7c3aed, #a78bfa); border-radius: 9999px; }
    .progress-labels { display: flex; justify-content: space-between; font-size: 11px; color: #94a3b8; }

    /* Timeline */
    .timeline { position: relative; padding-left: 24px; }
    .timeline::before { content: ''; position: absolute; left: 8px; top: 0; bottom: 0; width: 2px; background: #e2e8f0; }
    .timeline-item { position: relative; padding-bottom: 20px; }
    .timeline-item:last-child { padding-bottom: 0; }
    .timeline-dot { position: absolute; left: -20px; top: 3px; width: 14px; height: 14px; border-radius: 50%; background: #7c3aed; border: 2px solid white; box-shadow: 0 0 0 2px #e2e8f0; }
    .timeline-date { font-size: 11px; color: #94a3b8; margin-bottom: 3px; }
    .timeline-title { font-size: 13px; font-weight: 600; color: #1e293b; }
    .timeline-subtitle { font-size: 12px; color: #64748b; margin-top: 2px; }
    .timeline-note { font-size: 12px; color: #5b21b6; font-style: italic; margin-top: 4px; padding: 6px 10px; background: #f5f3ff; border-left: 3px solid #a78bfa; border-radius: 0 4px 4px 0; }

    /* Stage list */
    .stage-steps { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 32px; }
    .stage-step { display: flex; align-items: center; gap-4px; font-size: 11px; padding: 4px 8px; border-radius: 4px; }
    .stage-step.past { background: #dcfce7; color: #15803d; }
    .stage-step.current { background: #ede9fe; color: #5b21b6; font-weight: 700; }
    .stage-step.future { background: #f1f5f9; color: #94a3b8; }

    footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid #e2e8f0; text-align: center; font-size: 11px; color: #94a3b8; }
    @media print { body { padding: 20px; } }
  </style>
</head>
<body>

<div class="header">
  <div class="logo">Orkestria</div>
  <div class="generated">Généré le {{ "now"|date("d/m/Y à H:i") }}</div>
</div>

{% set stages = [
  'contact', 'meeting', 'engineer_assigned', 'quote_plan', 'quote_signed',
  'invoice_sent', 'deposit_received', 'design_started', 'design_completed',
  'client_signed', 'components_ordered', 'construction', 'subcontractors',
  'site_visit', 'paid'
] %}
{% set stageLabels = {
  'contact': 'Prise de contact',
  'meeting': 'Réunion',
  'engineer_assigned': 'Ingénieur assigné',
  'quote_plan': 'Plan de devis',
  'quote_signed': 'Devis signé',
  'invoice_sent': 'Facture envoyée',
  'deposit_received': 'Acompte reçu',
  'design_started': 'Début des plans',
  'design_completed': 'Plans finalisés',
  'client_signed': 'Signature client',
  'components_ordered': 'Commandes effectuées',
  'construction': 'Montage',
  'subcontractors': 'Sous-traitants',
  'site_visit': 'Visite de chantier',
  'paid': 'Paiement total'
} %}
{% set currentIdx = stages|keys|filter(k => stages[k] == project.pipelineStage.value)|first ?? 0 %}
{% set pct = ((currentIdx + 1) / stages|length * 100)|round %}

<div class="title-block">
  <h1>{{ project.title }}</h1>
  {% if project.client %}
    <div class="client-name">{{ project.client.name }}</div>
  {% endif %}
  {% if project.startDate or project.endDate %}
    <div class="dates">
      {% if project.startDate %}Début : {{ project.startDate|date("d/m/Y") }}{% endif %}
      {% if project.startDate and project.endDate %} · {% endif %}
      {% if project.endDate %}Fin prévue : {{ project.endDate|date("d/m/Y") }}{% endif %}
    </div>
  {% endif %}
</div>

<!-- KPIs -->
<div class="meta-grid">
  <div class="meta-card">
    <div class="label">Étape actuelle</div>
    <div class="value purple">
      <span class="stage-badge">{{ stageLabels[project.pipelineStage.value] ?? project.pipelineStage.value }}</span>
    </div>
  </div>
  <div class="meta-card">
    <div class="label">Avancement</div>
    <div class="value">{{ pct }} %</div>
  </div>
  <div class="meta-card">
    <div class="label">Transitions</div>
    <div class="value">{{ history|length }}</div>
  </div>
</div>

<!-- Progress bar -->
<div class="progress-section">
  <div class="section-title">Avancement du pipeline</div>
  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" style="width: {{ pct }}%"></div>
  </div>
  <div class="progress-labels">
    <span>{{ stageLabels[stages[0]] ?? stages[0] }}</span>
    <span>{{ stageLabels[stages[stages|length - 1]] ?? stages[stages|length - 1] }}</span>
  </div>
</div>

<!-- Stage map -->
<div class="stage-steps">
  {% for i, s in stages %}
    <div class="stage-step {{ i < currentIdx ? 'past' : (i == currentIdx ? 'current' : 'future') }}">
      {% if i < currentIdx %}✓ {% endif %}
      {{ stageLabels[s] ?? s }}
    </div>
  {% endfor %}
</div>

<!-- History timeline -->
{% if history|length > 0 %}
  <div class="section-title">Historique des transitions</div>
  <div class="timeline">
    {% for entry in history %}
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-date">{{ entry.changedAt|date("d/m/Y à H:i") }}</div>
        <div class="timeline-title">
          {{ stageLabels[entry.fromStage.value] ?? entry.fromStage.value }}
          →
          {{ stageLabels[entry.toStage.value] ?? entry.toStage.value }}
        </div>
        {% if entry.changedBy %}
          <div class="timeline-subtitle">Par {{ entry.changedBy.firstName }} {{ entry.changedBy.lastName }}</div>
        {% endif %}
        {% if entry.note %}
          <div class="timeline-note">{{ entry.note }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
{% else %}
  <div class="section-title">Historique des transitions</div>
  <p style="color: #94a3b8; font-size: 13px;">Aucun changement d'étape enregistré.</p>
{% endif %}

<footer>
  Orkestria — Rapport généré automatiquement · {{ project.title }}
</footer>

</body>
</html>
