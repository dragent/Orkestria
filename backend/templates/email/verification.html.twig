<!DOCTYPE html>
<html lang="fr" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Confirmez votre adresse e-mail — Orkestria</title>
  <!--[if mso]><xml>
    <o:OfficeDocumentSettings>
      <o:AllowPNG/>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings>
  </xml><![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">

  {{-- Outer wrapper: centers the card using table alignment instead of margin:auto --}}
  <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
         style="background-color:#f1f5f9;">
    <tr>
      <td align="center" style="padding-top:40px;padding-bottom:40px;padding-left:16px;padding-right:16px;">

        {{-- Card — border-radius is progressive enhancement; degrades to square in unsupported clients --}}
        <table width="560" cellpadding="0" cellspacing="0" border="0" role="presentation"
               style="width:560px;max-width:100%;background-color:#ffffff;border-radius:12px;">

          {{-- Header --}}
          <tr>
            <td align="center"
                style="background-color:#1e1b4b;border-radius:12px 12px 0 0;padding-top:40px;padding-bottom:40px;padding-left:48px;padding-right:48px;">
              <h1 style="margin:0;color:#ffffff;font-size:22px;font-weight:700;letter-spacing:-0.3px;line-height:1.3;">
                Orkestria
              </h1>
            </td>
          </tr>

          {{-- Body --}}
          <tr>
            <td style="padding-top:40px;padding-bottom:0;padding-left:48px;padding-right:48px;">

              <p style="margin:0;padding-bottom:16px;color:#475569;font-size:15px;line-height:1.6;">
                Bonjour <strong style="color:#1e293b;">{{ firstName }}</strong>,
              </p>

              <p style="margin:0;padding-bottom:16px;color:#475569;font-size:15px;line-height:1.6;">
                Merci de vous être inscrit sur <strong style="color:#1e293b;">Orkestria</strong>.
                Pour finaliser votre inscription, veuillez confirmer votre adresse e-mail en cliquant sur le bouton ci-dessous.
              </p>

              {{-- Spacer --}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
                <tr><td height="16" style="font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

              {{--
                CTA button.
                - Outlook Windows (2003–2019): VML RoundRect renders native rounded corners.
                - All other clients: standard <a> with border-radius as progressive enhancement.
              --}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
                <tr>
                  <td align="center">
                    <!--[if mso]>
                    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml"
                                 xmlns:w="urn:schemas-microsoft-com:office:word"
                                 href="{{ verificationUrl }}"
                                 style="height:50px;v-text-anchor:middle;width:260px;"
                                 arcsize="16%"
                                 strokecolor="#4f46e5"
                                 fillcolor="#4f46e5">
                      <w:anchorlock/>
                      <center style="color:#ffffff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:15px;font-weight:600;">
                        Confirmer mon adresse e-mail
                      </center>
                    </v:roundrect>
                    <![endif]-->
                    <!--[if !mso]><!-->
                    <a href="{{ verificationUrl }}"
                       style="display:inline-block;background-color:#4f46e5;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding-top:14px;padding-bottom:14px;padding-left:32px;padding-right:32px;border-radius:8px;">
                      Confirmer mon adresse e-mail
                    </a>
                    <!--<![endif]-->
                  </td>
                </tr>
              </table>

              {{-- Spacer --}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
                <tr><td height="24" style="font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

              <p style="margin:0;padding-bottom:16px;color:#94a3b8;font-size:13px;line-height:1.6;">
                Ce lien est valable pendant <strong style="color:#64748b;">24 heures</strong>.
                Si vous n'avez pas créé de compte, ignorez cet e-mail.
              </p>

              {{-- Fallback URL box — border-radius is progressive enhancement --}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
                <tr>
                  <td style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding-top:12px;padding-bottom:12px;padding-left:16px;padding-right:16px;font-size:12px;color:#94a3b8;word-break:break-all;word-wrap:break-word;overflow-wrap:break-word;">
                    {{ verificationUrl }}
                  </td>
                </tr>
              </table>

              {{-- Bottom spacer --}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
                <tr><td height="40" style="font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

            </td>
          </tr>

          {{-- Footer --}}
          <tr>
            <td align="center"
                style="border-top:1px solid #f1f5f9;padding-top:24px;padding-bottom:24px;padding-left:48px;padding-right:48px;font-size:12px;color:#94a3b8;">
              © {{ "now"|date("Y") }} Orkestria — tous droits réservés.
            </td>
          </tr>

        </table>
        {{-- /Card --}}

      </td>
    </tr>
  </table>

</body>
</html>
